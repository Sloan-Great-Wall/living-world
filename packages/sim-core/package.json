{
  "name": "@living-world/sim-core",
  "version": "0.0.1",
  "private": true,
  "description": "TypeScript port of pure-function sim primitives (dice resolver + social metrics). Parity-tested against Python.",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dice": "./src/dice.ts",
    "./socialMetrics": "./src/socialMetrics.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "regen-fixtures": "cd ../.. && .venv/bin/python packages/sim-core/scripts/dump_fixtures.py"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "@types/node": "^20.0.0"
  }
}
