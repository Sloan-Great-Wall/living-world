{
  "name": "dashboard-tauri",
  "version": "0.1.0",
  "type": "module",
  "description": "Tauri + Solid + TypeScript dashboard for the Living World sim.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle:check": "node scripts/check-bundle-size.mjs",
    "schema:gen": "openapi-typescript ../api-schema/openapi.json -o src/types/api.generated.ts"
  },
  "dependencies": {
    "@living-world/sim-core": "*",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "solid-js": "^1.9.3"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29.1.0",
    "openapi-typescript": "^7.13.0",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.5"
  }
}
