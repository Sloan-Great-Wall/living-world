              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Packs Available"
      }
    },
    "/api/personas": {
      "get": {
        "description": "Expose loaded YAML personas per pack — for Library 'Characters' tab.\n\nThese are the AUTHORED set, not just the spawned ones. Useful when\nyou want to see \"who could appear\" vs \"who's currently in the run\".",
        "operationId": "personas_api_personas_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/PersonaRow"
                  },
                  "title": "Response Personas Api Personas Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Personas"
      }
    },
    "/api/reset": {
      "post": {
        "description": "Drop the loaded world. The frontend should then re-call\n/api/bootstrap with the desired packs.",
        "operationId": "reset_api_reset_post",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Ok"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Reset"
      }
    },
    "/api/settings": {
      "get": {
        "description": "Settings shape is deep + dynamic — exposed as open dict for now.\nTyping it is a follow-up (one Pydantic model per section).",
        "operationId": "settings_get_api_settings_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Settings Get Api Settings Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Settings Get"
      },
      "post": {
        "description": "Patch the live settings + persist to settings.yaml.\n\nAccepts a partial dict — only top-level sections present in the\npayload are merged. Returns the merged settings dict.\n\nNOTE: Most settings only take effect on next bootstrap (engine\nis built from settings at bootstrap time). Caller should\nprompt the user to Reset → Simulate again after important\nchanges (model swap, packs, feature flags).",
        "operationId": "settings_set_api_settings_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "title": "Payload",
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Settings Set Api Settings Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Settings Set"
      }
    },
    "/api/social_graph": {
      "get": {
        "description": "Lightweight projection for client-side social-metrics compute.\n\nReturns just (agentId, packId, alive, relationships) — exactly\nwhat `@living-world/sim-core` `computeSocialMetrics` consumes.\nKeeping the heavy computation client-side proves the TS port is\na real consumer (not just an isomorphic re-implementation\nsitting unused). Server stays a thin data tap.",
        "operationId": "social_graph_api_social_graph_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SocialGraph"
                }
