#!/usr/bin/env bash
# Living World launcher — `./lw <subcommand>` is sugar for `lw <subcommand>`
# inside the project venv. The actual subcommand surface is defined by
# Typer in living_world/cli.py.
#
# Usage:
#   ./lw                  → print help (no default subcommand anymore)
#   ./lw smoke            → 8-tick run + invariants — primary regression check
#   ./lw run              → CLI simulation
#   ./lw serve            → FastAPI sim API for the Tauri dashboard
#   ./lw test             → pytest + smoke (CI-style)
#   ./lw install          → reinstall deps (use uv if available)
#
# For the desktop dashboard:
#   ./lw serve  &  npm run tauri dev --workspace=dashboard-tauri
#
# For the full verification gate (ruff + types + tests + TS build):
#   make check

set -e
cd "$(dirname "$0")"

# Bootstrap venv on first run (idempotent after that).
if [ ! -d ".venv" ]; then
  echo "→ First run — creating venv and installing deps..."
  python3 -m venv .venv
  # shellcheck disable=SC1091
  source .venv/bin/activate
  if .venv/bin/pip install --quiet uv 2>/dev/null && [ -x .venv/bin/uv ]; then
    .venv/bin/uv pip install --quiet -e ".[dev]"
  else
    pip install --quiet -e ".[dev]"
  fi
else
  # shellcheck disable=SC1091
  source .venv/bin/activate
fi

# Subcommand handling — pass through to the Typer CLI.
# `install` is intercepted because it's a tooling concern, not sim logic.
case "${1:-}" in
  ""|-h|--help)
    exec python -m living_world --help
    ;;
  install)
    if [ -x .venv/bin/uv ]; then
      .venv/bin/uv pip install -q -e ".[dev]"
    else
      pip install -q -e ".[dev]"
    fi
    echo "→ Installed."
    ;;
  test)
    # pytest path; `lw test` Typer command exists too but this skips
    # the smoke phase for fast iteration.
    shift
    exec pytest tests/ "$@"
    ;;
  *)
    exec python -m living_world "$@"
    ;;
esac
